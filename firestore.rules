# ---- Firebase Cloud Firestore Security Rules ----
# These rules enforce Role-Based Access Control (RBAC) and ownership checks.
# Replace with your own field names if you customize the schema.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in
          ['super_admin', 'principal', 'vice_principal'];
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------------- Users ----------------
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------- Public-ish content ----------------
    match /departments/{id} { allow read: if true; allow write: if isAdmin(); }
    match /courses/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /subjects/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /events/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /gallery/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /notices/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /news/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /faculty/{id}      { allow read: if true; allow write: if isAdmin() || userRole() == 'hod'; }
    match /books/{id}        { allow read: if true; allow write: if userRole() in ['admin','librarian']; }

    // ---------------- Student-owned data ----------------
    match /students/{id} {
      allow read: if isAdmin() || isOwner(id) ||
        userRole() in ['faculty','hod','accountant','parent'];
      allow write: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || userRole() in ['faculty','hod'];
      allow delete: if isAdmin();
    }

    match /results/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || userRole() in ['faculty','hod','accountant'];
    }

    match /fees/{id} {
      allow read: if isAdmin() || userRole() == 'accountant' || isOwner(id);
      allow write: if isAdmin() || userRole() == 'accountant';
    }

    match /applications/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(resource.data.userId);
    }

    match /placements/{id}  { allow read: if true; allow write: if isAdmin() || userRole() == 'placement_officer'; }
    match /companies/{id}   { allow read: if true; allow write: if isAdmin() || userRole() == 'placement_officer'; }
    match /library/{id}     { allow read: if isSignedIn(); allow write: if isAdmin() || userRole() == 'librarian'; }
    match /hostel/{id}      { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /transport/{id}   { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /certificates/{id}{ allow read: if true; allow write: if isAdmin(); }
    match /reports/{id}     { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /settings/{id}    { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /audit_logs/{id}  { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /scholarships/{id}{ allow read: if true; allow write: if isAdmin(); }

    // Catch-all: deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
